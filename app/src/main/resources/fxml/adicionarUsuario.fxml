<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdicionarUsuarioController">
   <bottom>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="ADICIONAR NOVO USUARIO" />
            <TextField fx:id="txtNome" promptText="Nome do usuario" />
            <TextField fx:id="txtLogin" promptText="Login do usuario" />
            <TextField fx:id="txtSenha" promptText="Senha do usuario" />
            <Label text="Selecione o tipo de usuario:" />
            <Button fx:id="btnAdministrador" mnemonicParsing="false" onAction="#selecionarAdministrador" text="Administrador" />
            <Button fx:id="btnGerente" mnemonicParsing="false" onAction="#selecionarGerente" text="Gerente" />
            <Button fx:id="btnCriar" mnemonicParsing="false" onAction="#criar" text="Criar" />
            <Label fx:id="lblMensagem" />
            <Button fx:id="btnVoltar" mnemonicParsing="false" onAction="#voltar" text="Voltar" />
         </children>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
      </VBox>
   </bottom>
</BorderPane>
